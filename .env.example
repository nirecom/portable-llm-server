# ============================================================
# portable-llm-server environment variables
# Copy to .env and fill in actual values
# ============================================================

# Server settings
HOST=0.0.0.0
PORT=8443

# TLS certificate files (generated by ./setup-certs.sh)
SSL_CERT_FILE=./certs/llm-server.pem
SSL_KEY_FILE=./certs/llm-server-key.pem
